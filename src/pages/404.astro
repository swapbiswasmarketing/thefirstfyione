---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 · Strictly FYI" description="This page isn't in the archive.">
  <section class="nf">
    <div class="wrap-narrow">
      <div class="nf-glyph" aria-hidden="true">?</div>
      <p class="eyebrow">Error 404</p>
      <h1>This one's not in the <span class="hl">archive</span>.</h1>
      <p class="nf-lede">
        The page you're after has wandered off - or never existed. But here's something that does:
        <em>a group of flamingos is called a "flamboyance."</em> You're welcome.
      </p>
      <div class="nf-cta">
        <a href="/" class="btn btn-primary">Back home →</a>
        <a href="/blog/" class="btn btn-ghost">Read something true</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .nf { text-align: center; padding: clamp(4rem, 12vw, 8rem) 0; }
  .nf-glyph { font-family: var(--serif); font-size: clamp(5rem, 16vw, 9rem); line-height: 1; color: var(--indigo); }
  .nf h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); margin: 0.6rem auto; max-width: 18ch; }
  .nf-lede { color: var(--ink-soft); font-size: 1.2rem; max-width: 46ch; margin: 0 auto 2rem; }
  .nf-lede em { font-family: var(--serif); font-style: italic; color: var(--ink); }
  .nf-cta { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
</style>
