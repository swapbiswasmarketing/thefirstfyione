---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const catLabel: Record<string, string> = {
  science: "Science", history: "History", tech: "Tech",
  culture: "Culture", everyday: "Everyday", curiosity: "Curiosity",
};
const cats = ["all", "science", "history", "tech", "culture", "everyday", "curiosity"];
---

<Layout title="Read · Strictly FYI" description="Every story from Strictly FYI - short, smart, well-sourced pieces on science, history, tech, culture, and everyday curiosities.">
  <section class="arch-hero">
    <div class="wrap">
      <p class="eyebrow">The archive</p>
      <h1>Everything worth knowing.</h1>
      <p class="lede">Short, well-sourced stories on the fascinating. Filter by topic.</p>
      <div class="filters" role="group" aria-label="Filter stories by topic">
        {cats.map((c) => (
          <button class={`chip ${c === "all" ? "on" : ""}`} data-cat={c} type="button">
            {c === "all" ? "All stories" : catLabel[c]}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="story-grid" id="grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="story" data-cat={post.data.category}>
            <span class="cat">{catLabel[post.data.category] ?? "🧩 Curiosity"}</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="story-meta mono">
              {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              {post.data.readingTime ? ` · ${post.data.readingTime}` : ""}
            </span>
          </a>
        ))}
      </div>
      <p class="empty" id="empty" hidden>No stories in this topic yet - check back soon.</p>
    </div>
  </section>
</Layout>

<style>
  .arch-hero { padding: clamp(3rem, 8vw, 5rem) 0 1.5rem; }
  .arch-hero h1 { font-size: clamp(2.4rem, 7vw, 4.2rem); margin: 0.4rem 0; }
  .arch-hero .lede { color: var(--ink-soft); font-size: 1.1rem; margin-bottom: 2rem; }
  .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .chip { font-family: var(--sans); font-weight: 500; font-size: 0.9rem; padding: 0.5rem 1rem; border-radius: 999px; cursor: pointer; background: var(--paper-2); border: 1.5px solid var(--line-2); color: var(--ink-soft); transition: all 0.15s; }
  .chip:hover { border-color: var(--indigo); color: var(--indigo-deep); }
  .chip.on { background: var(--indigo); border-color: var(--indigo); color: #fff; }

  .story-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  .story { background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.7rem; text-decoration: none; color: var(--ink); display: flex; flex-direction: column; gap: 0.55rem; box-shadow: var(--shadow); transition: transform 0.18s, box-shadow 0.18s; }
  .story:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .story .cat { align-self: flex-start; }
  .story h2 { font-size: 1.5rem; line-height: 1.13; }
  .story p { color: var(--ink-soft); font-size: 0.98rem; flex: 1; }
  .story-meta { color: var(--ink-faint); font-size: 0.8rem; }
  .empty { text-align: center; color: var(--ink-soft); font-size: 1.15rem; padding: 3rem 0; font-family: var(--serif); font-style: italic; }
  @media (max-width: 760px) { .story-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function apply(cat: string) {
    const cards = document.querySelectorAll<HTMLElement>(".story");
    let shown = 0;
    cards.forEach((c) => {
      const show = cat === "all" || c.dataset.cat === cat;
      c.style.display = show ? "" : "none";
      if (show) shown++;
    });
    document.querySelectorAll(".chip").forEach((ch) => ch.classList.toggle("on", (ch as HTMLElement).dataset.cat === cat));
    const empty = document.getElementById("empty");
    if (empty) (empty as HTMLElement).hidden = shown !== 0;
  }
  document.querySelectorAll(".chip").forEach((ch) => ch.addEventListener("click", () => apply((ch as HTMLElement).dataset.cat || "all")));
  const initial = new URLSearchParams(location.search).get("cat");
  if (initial) apply(initial);
</script>
