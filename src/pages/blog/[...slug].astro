---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const sorted = [...posts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, sorted } }));
}

const { post, sorted } = Astro.props;
const { Content } = await render(post);

const catLabel: Record<string, string> = {
  science: "Science", history: "History", tech: "Tech",
  culture: "Culture", everyday: "Everyday", curiosity: "Curiosity",
};
const catEmoji: Record<string, string> = {
  science: "🔬", history: "📜", tech: "💡", culture: "🎭", everyday: "☕", curiosity: "🧩",
};

const more = sorted.filter((p) => p.id !== post.id).slice(0, 2);

const site = Astro.site ?? new URL("https://strictly.fyi");
const url = new URL(`/blog/${post.id}/`, site).href;
const published = post.data.pubDate.toISOString();
const modified = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const section = catLabel[post.data.category] ?? "Curiosity";

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  image: new URL("/og.png", site).href,
  datePublished: published,
  dateModified: modified,
  articleSection: section,
  author: { "@type": "Organization", name: "Strictly FYI", url: site.href },
  publisher: { "@type": "Organization", name: "Strictly FYI", logo: { "@type": "ImageObject", url: new URL("/og.png", site).href } },
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: site.href },
    { "@type": "ListItem", position: 2, name: "Read", item: new URL("/blog/", site).href },
    { "@type": "ListItem", position: 3, name: post.data.title, item: url },
  ],
};
---

<Layout
  title={`${post.data.title} · Strictly FYI`}
  description={post.data.description}
  type="article"
  publishedTime={published}
  modifiedTime={modified}
  section={section}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

  <div class="read-progress" aria-hidden="true"><span id="rp-bar"></span></div>
  <button id="to-top" class="to-top" type="button" aria-label="Back to top" hidden>
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <article class="post">
    <div class="wrap-narrow">
      <nav class="crumbs mono" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span> <a href="/blog/">Read</a> <span>/</span> <span class="crumb-cur">{section}</span>
      </nav>
      <span class="cat">{catEmoji[post.data.category]} {section}</span>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <div class="byline mono">
        <span>Strictly FYI</span>
        <span>·</span>
        <time datetime={published}>{post.data.pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</time>
        {post.data.readingTime && <><span>·</span><span>{post.data.readingTime}</span></>}
      </div>
      <hr class="rule" />
    </div>

    <div class="wrap-narrow prose">
      <Content />
    </div>

    <div class="wrap-narrow">
      <div class="post-cta">
        <span class="hl cta-badge">The weekly FYI</span>
        <h3>Liked this? Get five like it every week.</h3>
        <a href="/#subscribe" class="btn btn-primary">Subscribe →</a>
      </div>
    </div>

    {more.length > 0 && (
      <div class="wrap keep">
        <p class="eyebrow">Keep reading</p>
        <div class="more-grid">
          {more.map((p) => (
            <a href={`/blog/${p.id}/`} class="more-card">
              <span class="cat">{catEmoji[p.data.category]} {catLabel[p.data.category]}</span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>

<style>
  .post { padding-top: clamp(2rem, 5vw, 3.5rem); }
  .crumbs { font-size: 0.75rem; color: var(--ink-faint); margin-bottom: 1.4rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .crumbs a { color: var(--ink-soft); text-decoration: none; }
  .crumbs a:hover { color: var(--indigo); }
  .crumb-cur { color: var(--indigo); }
  .post h1 { font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin: 0.6rem 0 0.8rem; }
  .dek { font-family: var(--serif); font-style: italic; font-size: 1.3rem; color: var(--ink-soft); line-height: 1.4; }
  .byline { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin: 1.4rem 0; color: var(--ink-faint); font-size: 0.8rem; }
  .rule { border: none; border-top: 1px solid var(--line); margin: 0; }

  .prose { margin-top: 2rem; font-size: 1.18rem; line-height: 1.75; color: #2c2d34; }
  .prose :global(h2) { font-family: var(--serif); color: var(--ink); font-size: clamp(1.6rem, 3.5vw, 2.1rem); margin: 2.6rem 0 0.8rem; }
  .prose :global(h3) { font-size: 1.4rem; margin: 2rem 0 0.6rem; }
  .prose :global(p) { margin: 1.1rem 0; }
  .prose :global(ul), .prose :global(ol) { margin: 1.1rem 0 1.1rem 1.4rem; }
  .prose :global(li) { margin: 0.5rem 0; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(a) { color: var(--indigo-deep); }
  .prose :global(blockquote) { margin: 1.8rem 0; padding: 1.1rem 1.6rem; border-left: 4px solid var(--indigo); background: var(--paper-2); border-radius: 0 var(--radius) var(--radius) 0; font-family: var(--serif); font-style: italic; font-size: 1.28rem; color: var(--ink); }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5rem 0; }
  .prose :global(code) { font-family: var(--mono); background: var(--paper-deep); padding: 0.15em 0.4em; border-radius: 5px; font-size: 0.88em; }
  .prose :global(mark) { background: var(--highlight); padding: 0 0.15em; }

  .post-cta { text-align: center; border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 2.4rem; background: var(--paper-2); margin: 3rem 0; box-shadow: var(--shadow); }
  .cta-badge { display: inline-block; font-family: var(--mono); font-weight: 700; font-size: 0.82rem; padding: 0.1rem 0.5rem; }
  .post-cta h3 { font-size: 1.6rem; margin: 0.7rem 0 1.3rem; }

  .keep { margin-top: 3.5rem; }
  .keep .eyebrow { display: block; margin-bottom: 1rem; }
  .more-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .more-card { border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem; text-decoration: none; color: var(--ink); background: var(--paper-2); box-shadow: var(--shadow); transition: transform 0.18s, box-shadow 0.18s; }
  .more-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .more-card .cat { margin-bottom: 0.5rem; }
  .more-card h3 { font-size: 1.3rem; margin: 0.3rem 0 0.4rem; }
  .more-card p { color: var(--ink-soft); font-size: 0.95rem; }
  @media (max-width: 720px) { .more-grid { grid-template-columns: 1fr; } }

  .read-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; background: transparent; z-index: 90; }
  .read-progress span { display: block; height: 100%; width: 0%; background: var(--indigo); transition: width 0.1s linear; }
  .to-top { position: fixed; right: 1.4rem; bottom: 1.4rem; width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center; background: var(--indigo); color: #fff; border: none; cursor: pointer; box-shadow: var(--shadow-lift); z-index: 80; opacity: 0; pointer-events: none; transform: translateY(10px); transition: opacity 0.25s, transform 0.25s; }
  .to-top[hidden] { display: none; }
  .to-top.show { opacity: 1; pointer-events: auto; transform: none; }
  .to-top:hover { background: var(--indigo-deep); }
  .to-top svg { width: 20px; height: 20px; }
</style>

<script>
  const bar = document.getElementById("rp-bar");
  const toTop = document.getElementById("to-top");
  function onScroll() {
    const doc = document.documentElement;
    const st = doc.scrollTop || document.body.scrollTop;
    const h = doc.scrollHeight - doc.clientHeight;
    if (bar) bar.style.width = (h > 0 ? (st / h) * 100 : 0) + "%";
    if (toTop) { toTop.hidden = false; toTop.classList.toggle("show", st > 600); }
  }
  if (toTop) toTop.hidden = true;
  document.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
  toTop?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
</script>
