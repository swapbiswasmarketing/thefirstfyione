---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 4);

const catLabel: Record<string, string> = {
  positioning: "POSITIONING",
  gtm: "GO-TO-MARKET",
  launches: "LAUNCHES",
  messaging: "MESSAGING",
  brief: "THE BRIEF",
};

const rules = [
  { n: "01", t: "Signal, not noise", d: "Every issue is the 3-5 things that actually matter this week, filtered from the firehose so you don't have to drink it." },
  { n: "02", t: "A point of view", d: "This is not a neutral news roundup. You get a take. Sometimes you'll disagree. That's the point - it's a brief, not a Wikipedia entry." },
  { n: "03", t: "Respect your time", d: "Skimmable, subhead-driven, done in five minutes. If a paragraph isn't earning its place, it gets cut before you ever see it." },
  { n: "04", t: "Receipts included", d: "Claims get sources. Frameworks get examples. Nothing here is vibes-based thought leadership." },
];

const gets = [
  { k: "THE WEEKLY", t: "5 things worth knowing", d: "Curated GTM, positioning, and product-marketing moves - what happened, and why it matters to your roadmap." },
  { k: "TEARDOWNS", t: "How the good ones did it", d: "We reverse-engineer real launches and positioning plays. What worked, what we'd change, what you can steal." },
  { k: "PLAYBOOKS", t: "Frameworks you'll actually use", d: "Battlecards, launch tiers, messaging tests - the reusable stuff, minus the consultant markup." },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track mono">
        <span>SIGNAL NOT NOISE</span><span class="sep">//</span>
        <span>FILED WEEKLY</span><span class="sep">//</span>
        <span>NO FLUFF</span><span class="sep">//</span>
        <span>FOR YOUR INFORMATION</span><span class="sep">//</span>
        <span>SIGNAL NOT NOISE</span><span class="sep">//</span>
        <span>FILED WEEKLY</span><span class="sep">//</span>
        <span>NO FLUFF</span><span class="sep">//</span>
        <span>FOR YOUR INFORMATION</span><span class="sep">//</span>
      </div>
    </div>

    <div class="wrap hero-inner">
      <div class="hero-left">
        <p class="tag reveal">// the go-to-market brief for product marketers</p>
        <h1 class="masthead reveal">
          <span class="line">STRICTLY</span>
          <span class="line fyi-line"><mark>FYI</mark></span>
        </h1>
        <p class="hero-dek reveal">
          The stuff worth knowing in positioning, launches, and go-to-market -
          filtered to signal, delivered with a point of view, read in five minutes.
          <strong>Strictly for your information.</strong>
        </p>
        <div class="hero-cta reveal">
          <a href="#subscribe" class="btn btn-signal">Get the brief →</a>
          <a href="/blog/" class="btn btn-ghost">Read the archive</a>
        </div>
        <p class="hero-fine mono reveal">// 2,400+ PMMs &amp; founders on the distribution list · unsubscribe anytime</p>
      </div>

      <aside class="hero-card reveal" aria-label="This week's brief">
        <div class="card-head mono">
          <span class="filecode">FYI-{String(posts.length).padStart(3, "0")}</span>
          <span>LATEST FILING</span>
        </div>
        <div class="card-body">
          {latest[0] ? (
            <>
              <span class="tag tag-signal">{catLabel[latest[0].data.category]}</span>
              <a href={`/blog/${latest[0].id}/`} class="card-title">{latest[0].data.title}</a>
              <p class="card-dek">{latest[0].data.description}</p>
              <a href={`/blog/${latest[0].id}/`} class="card-link mono">OPEN FILE →</a>
            </>
          ) : (
            <p class="card-dek">First brief filing imminent.<span class="cursor">▮</span></p>
          )}
        </div>
        <div class="card-foot mono">
          <span>STATUS: DECLASSIFIED</span>
          <span class="stamp">FYI</span>
        </div>
      </aside>
    </div>
  </section>

  <!-- ============ EDITORIAL STANDARD ============ -->
  <section class="section rules-section">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="tag tag-signal">// editorial standard</p>
        <h2>Four rules. Non-negotiable.</h2>
      </div>
      <div class="rule-grid">
        {rules.map((r) => (
          <article class="rule reveal">
            <span class="rule-n mono">{r.n}</span>
            <h3>{r.t}</h3>
            <p>{r.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ LATEST BRIEFS ============ -->
  <section class="section briefs-section">
    <div class="wrap">
      <div class="sec-head row reveal">
        <div>
          <p class="tag tag-signal">// the archive</p>
          <h2>Recent filings.</h2>
        </div>
        <a href="/blog/" class="btn btn-ghost btn-sm">All briefs →</a>
      </div>
      <div class="brief-list">
        {latest.map((post, i) => (
          <a href={`/blog/${post.id}/`} class="brief-row reveal">
            <span class="brief-code mono">{post.data.filecode ?? `FYI-${String(posts.length - i).padStart(3, "0")}`}</span>
            <div class="brief-main">
              <span class="tag tag-signal">{catLabel[post.data.category]}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
            <div class="brief-meta mono">
              <span>{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })}</span>
              <span>{post.data.readingTime ?? ""}</span>
              <span class="brief-open">OPEN →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHAT YOU GET ============ -->
  <section class="section what-section" id="what">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="tag tag-signal">// what lands in your inbox</p>
        <h2>Three formats. Zero fluff.</h2>
      </div>
      <div class="get-grid">
        {gets.map((g) => (
          <div class="get reveal">
            <span class="get-k mono">{g.k}</span>
            <h3>{g.t}</h3>
            <p>{g.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SUBSCRIBE ============ -->
  <section class="section subscribe-section" id="subscribe">
    <div class="wrap-narrow sub-card reveal">
      <div class="sub-stamp mono" aria-hidden="true">FOR YOUR<br />INFORMATION</div>
      <p class="tag tag-signal">// join the distribution list</p>
      <h2>Get the brief before your competitors do.</h2>
      <p class="sub-dek">
        One tight, opinionated go-to-market brief. Filed weekly. Read in five minutes.
        No webinars, no "synergies," no 2,000-word intros.
      </p>
      <form class="sub-form" onsubmit="event.preventDefault(); this.querySelector('.sub-ok').hidden=false; this.querySelector('input').value='';">
        <input type="email" required placeholder="you@company.com" aria-label="Work email" />
        <button type="submit" class="btn btn-signal">Subscribe</button>
        <p class="sub-ok mono" hidden>// ACCESS GRANTED. Check your inbox to confirm. ▮</p>
      </form>
      <p class="sub-fine mono">// 2,400+ readers · filed every Thursday · clearance: public</p>
    </div>
  </section>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero { position: relative; padding-bottom: clamp(2rem, 6vw, 4rem); }
  .marquee { border-block: 1px solid var(--line); background: rgba(230, 255, 77, 0.03); overflow: hidden; padding: 0.55rem 0; }
  .marquee-track { display: inline-flex; gap: 1.2rem; align-items: center; white-space: nowrap; font-size: 0.78rem; letter-spacing: 0.2em; color: var(--signal-dim); animation: scroll-x 26s linear infinite; }
  .marquee-track .sep { color: var(--faint); }
  @keyframes scroll-x { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .hero-inner { display: grid; grid-template-columns: 1.5fr 1fr; gap: 2.5rem; align-items: center; padding-top: clamp(2.5rem, 7vw, 5rem); }
  .hero-left .tag { display: block; margin-bottom: 1.2rem; }
  .masthead { font-size: clamp(3.4rem, 13vw, 8.5rem); font-weight: 700; line-height: 0.86; letter-spacing: -0.04em; }
  .masthead .line { display: block; }
  .masthead mark { background: var(--signal); color: var(--bg); padding: 0 0.12em; }
  .fyi-line { position: relative; }
  .hero-dek { font-size: clamp(1.05rem, 2.2vw, 1.3rem); color: var(--muted); max-width: 52ch; margin: 1.8rem 0 2rem; }
  .hero-dek strong { color: var(--ink); }
  .hero-cta { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .hero-fine { margin-top: 1.4rem; color: var(--faint); font-size: 0.75rem; letter-spacing: 0.06em; }

  /* Hero card (dossier) */
  .hero-card { background: var(--panel); border: 1px solid var(--line-2); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
  .card-head { display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 1rem; border-bottom: 1px solid var(--line); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--faint); }
  .card-body { padding: 1.4rem; }
  .card-body .tag-signal { display: block; margin-bottom: 0.7rem; }
  .card-title { display: block; font-family: var(--grotesk); font-weight: 700; font-size: 1.4rem; line-height: 1.12; color: var(--ink); text-decoration: none; letter-spacing: -0.02em; }
  .card-title:hover { color: var(--signal); }
  .card-dek { color: var(--muted); font-size: 0.95rem; margin: 0.7rem 0 1rem; }
  .card-link { color: var(--signal); text-decoration: none; font-size: 0.78rem; letter-spacing: 0.08em; }
  .card-foot { display: flex; justify-content: space-between; align-items: center; padding: 0.7rem 1rem; border-top: 1px solid var(--line); font-size: 0.7rem; color: var(--faint); }
  .card-foot .stamp { color: var(--danger); border: 1.5px solid var(--danger); padding: 0 0.35rem; border-radius: 2px; transform: rotate(-4deg); font-weight: 600; letter-spacing: 0.1em; }
  .cursor { animation: blink 1.1s step-end infinite; color: var(--signal); }
  @keyframes blink { 50% { opacity: 0; } }

  @media (max-width: 880px) { .hero-inner { grid-template-columns: 1fr; } .hero-card { max-width: 460px; } }

  /* ---------- SECTION HEADS ---------- */
  .sec-head { margin-bottom: 2.4rem; }
  .sec-head h2 { font-size: clamp(1.8rem, 4.5vw, 3rem); margin-top: 0.5rem; }
  .sec-head.row { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; flex-wrap: wrap; }

  /* ---------- RULES ---------- */
  .rule-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .rule { background: var(--panel); padding: 1.8rem 1.5rem; }
  .rule-n { font-size: 1.6rem; color: var(--signal); font-weight: 600; }
  .rule h3 { font-size: 1.2rem; margin: 0.6rem 0 0.5rem; }
  .rule p { color: var(--muted); font-size: 0.92rem; }
  @media (max-width: 900px) { .rule-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .rule-grid { grid-template-columns: 1fr; } }

  /* ---------- BRIEFS ---------- */
  .brief-list { border-top: 1px solid var(--line); }
  .brief-row { display: grid; grid-template-columns: 90px 1fr auto; gap: 1.5rem; align-items: center; padding: 1.6rem 0.5rem; border-bottom: 1px solid var(--line); text-decoration: none; color: var(--ink); transition: background 0.15s, padding 0.15s; }
  .brief-row:hover { background: var(--panel); padding-inline: 1rem; }
  .brief-code { color: var(--signal); font-size: 0.82rem; align-self: start; padding-top: 0.2rem; }
  .brief-main .tag-signal { display: block; margin-bottom: 0.4rem; }
  .brief-main h3 { font-size: 1.35rem; margin-bottom: 0.35rem; line-height: 1.15; }
  .brief-main p { color: var(--muted); font-size: 0.95rem; max-width: 62ch; }
  .brief-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; font-size: 0.72rem; color: var(--faint); letter-spacing: 0.05em; text-align: right; }
  .brief-open { color: var(--signal); }
  @media (max-width: 760px) {
    .brief-row { grid-template-columns: 1fr; gap: 0.5rem; }
    .brief-meta { flex-direction: row; align-items: center; gap: 1rem; }
  }

  /* ---------- WHAT YOU GET ---------- */
  .what-section { background: var(--panel); border-block: 1px solid var(--line); }
  .get-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .get { border: 1px solid var(--line-2); border-radius: var(--radius); padding: 1.8rem; background: var(--bg); transition: border-color 0.15s, transform 0.15s; }
  .get:hover { border-color: var(--signal); transform: translateY(-3px); }
  .get-k { color: var(--signal); font-size: 0.72rem; letter-spacing: 0.14em; }
  .get h3 { font-size: 1.3rem; margin: 0.6rem 0 0.5rem; }
  .get p { color: var(--muted); font-size: 0.95rem; }
  @media (max-width: 820px) { .get-grid { grid-template-columns: 1fr; } }

  /* ---------- SUBSCRIBE ---------- */
  .sub-card { position: relative; border: 1px solid var(--line-2); border-radius: var(--radius); background: var(--panel); padding: clamp(2.2rem, 5vw, 3.4rem); overflow: hidden; }
  .sub-stamp { position: absolute; right: 1.2rem; top: 1.2rem; color: var(--danger); border: 2px solid var(--danger); padding: 0.4rem 0.6rem; border-radius: 3px; font-size: 0.72rem; line-height: 1.1; letter-spacing: 0.08em; text-align: center; transform: rotate(8deg); opacity: 0.55; font-weight: 600; }
  .sub-card h2 { font-size: clamp(1.7rem, 4vw, 2.6rem); margin: 0.6rem 0; max-width: 20ch; }
  .sub-dek { color: var(--muted); max-width: 52ch; margin-bottom: 1.6rem; }
  .sub-form { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .sub-form input { flex: 1; min-width: 240px; padding: 0.85rem 1.1rem; border-radius: var(--radius); border: 1px solid var(--line-2); background: var(--bg); color: var(--ink); font-family: var(--mono); font-size: 0.95rem; }
  .sub-form input::placeholder { color: var(--faint); }
  .sub-form input:focus { outline: none; border-color: var(--signal); box-shadow: 0 0 0 3px rgba(230,255,77,0.12); }
  .sub-ok { flex-basis: 100%; color: var(--signal); font-size: 0.85rem; margin-top: 0.3rem; }
  .sub-fine { color: var(--faint); font-size: 0.72rem; margin-top: 1.2rem; letter-spacing: 0.05em; }
</style>
