---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id).slice(0, 6);

const cats = [
  { key: "science", n: "01", name: "Science", note: "How the universe actually works" },
  { key: "history", n: "02", name: "History", note: "The stories behind the story" },
  { key: "tech", n: "03", name: "Tech", note: "Why the things around you work" },
  { key: "culture", n: "04", name: "Culture", note: "Ideas, language, and why we do what we do" },
  { key: "everyday", n: "05", name: "Everyday", note: "The hidden logic of ordinary life" },
  { key: "curiosity", n: "06", name: "Curiosity", note: "The wonderfully, oddly true" },
];
const catLabel: Record<string, string> = Object.fromEntries(cats.map((c) => [c.key, c.name]));

const facts = [
  "Honey found in 3,000-year-old Egyptian tombs was still edible.",
  "A day on Venus is longer than its year.",
  "Bananas are botanically berries. Strawberries are not.",
  "Octopuses have three hearts and blue blood.",
  "The Eiffel Tower can be ~15 cm taller in summer heat.",
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-inner">
      <p class="eyebrow reveal">The general-interest field guide to the fascinating</p>
      <h1 class="hero-title reveal">
        Interesting things, <span class="hl">strictly</span> for your information.
      </h1>
      <p class="hero-sub reveal">
        Short, smart, well-sourced stories about science, history, tech, culture, and the
        quiet wonders of everyday life. The stuff that makes you go <em>"huh, I didn't know that."</em>
      </p>
      <div class="hero-cta reveal">
        <a href="/blog/" class="btn btn-primary">Start reading →</a>
        <a href="#subscribe" class="btn btn-ghost">Get the weekly FYI</a>
      </div>
    </div>
  </section>

  <!-- ============ FEATURED ============ -->
  {featured && (
    <section class="section featured-section">
      <div class="wrap">
        <p class="tag tag-accent reveal">// featured</p>
        <a href={`/blog/${featured.id}/`} class="feature reveal">
          <div class="feature-body">
            <span class="cat">{catLabel[featured.data.category] ?? "Curiosity"}</span>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <span class="feature-meta mono">
              {featured.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              {featured.data.readingTime ? ` · ${featured.data.readingTime}` : ""} · Read →
            </span>
          </div>
          <div class="feature-side" aria-hidden="true">
            <span class="feature-num mono">Nº 01</span>
            <span class="feature-mark">FYI</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ============ TOPICS ============ -->
  <section class="section topics-section" id="topics">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Browse by topic</p>
        <h2>Six ways to fall down a rabbit hole.</h2>
      </div>
      <div class="topic-grid">
        {cats.map((c) => (
          <a href={`/blog/?cat=${c.key}`} class="topic reveal">
            <span class="topic-n mono">{c.n}</span>
            <div class="topic-body">
              <h3>{c.name}</h3>
              <p>{c.note}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ LATEST ============ -->
  <section class="section latest-section">
    <div class="wrap">
      <div class="sec-head row reveal">
        <div>
          <p class="eyebrow">Fresh from the desk</p>
          <h2>Latest stories.</h2>
        </div>
        <a href="/blog/" class="btn btn-ghost btn-sm">All stories →</a>
      </div>
      <div class="story-grid">
        {rest.map((post) => (
          <a href={`/blog/${post.id}/`} class="story reveal">
            <span class="cat">{catLabel[post.data.category] ?? "Curiosity"}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="story-meta mono">
              {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              {post.data.readingTime ? ` · ${post.data.readingTime}` : ""}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FACT BAND ============ -->
  <section class="fact-band">
    <div class="wrap">
      <span class="fact-label mono">One thing worth knowing</span>
      <blockquote id="fact">{facts[0]}</blockquote>
    </div>
  </section>

  <!-- ============ SUBSCRIBE ============ -->
  <section class="section sub-section" id="subscribe">
    <div class="wrap-narrow sub-card reveal">
      <span class="hl sub-badge">The weekly FYI</span>
      <h2>One email. Five things worth knowing.</h2>
      <p>Every week: a handful of genuinely interesting, well-sourced things - decoded in plain English, read in five minutes. No spam, no filler.</p>
      <form class="sub-form" onsubmit="event.preventDefault(); this.querySelector('.sub-ok').hidden=false; this.querySelector('input').value='';">
        <input type="email" required placeholder="you@example.com" aria-label="Email address" />
        <button type="submit" class="btn btn-primary">Subscribe</button>
        <p class="sub-ok" hidden>✓ You're in. Check your inbox to confirm.</p>
      </form>
      <p class="sub-fine mono">Join curious readers · unsubscribe anytime</p>
    </div>
  </section>
</Layout>

<style>
  .hero { padding: clamp(3.5rem, 10vw, 7rem) 0 clamp(2rem, 5vw, 3.5rem); }
  .hero-inner { max-width: 900px; }
  .hero .eyebrow { display: inline-block; margin-bottom: 1.2rem; }
  .hero-title { font-family: var(--serif); font-size: clamp(2.6rem, 7vw, 5rem); font-weight: 600; line-height: 1.02; letter-spacing: -0.02em; }
  .hero-sub { font-size: clamp(1.1rem, 2.2vw, 1.35rem); color: var(--ink-soft); max-width: 56ch; margin: 1.6rem 0 2rem; }
  .hero-sub em { font-family: var(--serif); font-style: italic; color: var(--ink); }
  .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }

  .sec-head { max-width: 640px; margin-bottom: 2.4rem; }
  .sec-head h2 { font-size: clamp(1.8rem, 4.5vw, 2.9rem); margin-top: 0.5rem; }
  .sec-head.row { display: flex; justify-content: space-between; align-items: flex-end; max-width: none; gap: 1rem; flex-wrap: wrap; }

  /* Featured */
  .featured-section .tag-accent { display: block; margin-bottom: 1rem; }
  .feature { display: grid; grid-template-columns: 1fr 220px; gap: 0; text-decoration: none; color: var(--ink); background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); transition: transform 0.2s, box-shadow 0.2s; }
  .feature:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .feature-body { padding: clamp(1.8rem, 4vw, 3rem); }
  .feature-body .cat { margin-bottom: 1rem; }
  .feature-body h2 { font-size: clamp(1.7rem, 4vw, 2.8rem); line-height: 1.08; margin-bottom: 0.7rem; }
  .feature-body p { color: var(--ink-soft); font-size: 1.1rem; max-width: 52ch; margin-bottom: 1.2rem; }
  .feature-meta { color: var(--ink-faint); font-size: 0.82rem; }
  .feature-side { background: var(--indigo); display: grid; place-items: center; position: relative; }
  .feature-num { position: absolute; top: 1rem; left: 1rem; color: rgba(255,255,255,0.72); font-size: 0.72rem; letter-spacing: 0.2em; }
  .feature-mark { font-family: var(--serif); font-weight: 700; font-size: 3.2rem; letter-spacing: -0.02em; color: #fff; }
  @media (max-width: 720px) { .feature { grid-template-columns: 1fr; } .feature-side { min-height: 88px; } .feature-mark { font-size: 2.2rem; } }

  /* Topics */
  .topics-section { background: var(--paper-deep); border-block: 1px solid var(--line); }
  .topic-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .topic { display: flex; gap: 1rem; align-items: baseline; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.5rem 1.6rem; text-decoration: none; color: var(--ink); transition: border-color 0.18s, background 0.18s; }
  .topic:hover { border-color: var(--indigo); background: color-mix(in srgb, var(--indigo) 4%, var(--paper-2)); }
  .topic-n { font-size: 0.92rem; color: var(--indigo); font-weight: 700; letter-spacing: 0.04em; flex-shrink: 0; }
  .topic h3 { font-size: 1.3rem; margin: 0 0 0.3rem; }
  .topic p { color: var(--ink-soft); font-size: 0.95rem; }
  @media (max-width: 820px) { .topic-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .topic-grid { grid-template-columns: 1fr; } }

  /* Latest */
  .story-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .story { background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem; text-decoration: none; color: var(--ink); display: flex; flex-direction: column; gap: 0.5rem; box-shadow: var(--shadow); transition: transform 0.18s, box-shadow 0.18s; }
  .story:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .story .cat { align-self: flex-start; }
  .story h3 { font-size: 1.3rem; line-height: 1.15; }
  .story p { color: var(--ink-soft); font-size: 0.97rem; flex: 1; }
  .story-meta { color: var(--ink-faint); font-size: 0.78rem; }
  @media (max-width: 900px) { .story-grid { grid-template-columns: 1fr; } }

  /* Fact band */
  .fact-band { background: var(--ink); color: var(--paper); padding: clamp(2.5rem, 6vw, 4rem) 0; }
  .fact-label { color: var(--highlight); font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; }
  .fact-band blockquote { font-family: var(--serif); font-size: clamp(1.5rem, 4vw, 2.4rem); line-height: 1.25; margin-top: 0.8rem; max-width: 26ch; color: var(--paper); transition: opacity 0.4s; }

  /* Subscribe */
  .sub-card { text-align: center; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: clamp(2.2rem, 5vw, 3.4rem); box-shadow: var(--shadow); }
  .sub-badge { display: inline-block; font-family: var(--mono); font-weight: 700; font-size: 0.82rem; padding: 0.1rem 0.5rem; }
  .sub-card h2 { font-size: clamp(1.7rem, 4vw, 2.6rem); margin: 0.9rem 0 0.6rem; }
  .sub-card > p { color: var(--ink-soft); max-width: 48ch; margin: 0 auto 1.6rem; }
  .sub-form { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }
  .sub-form input { flex: 1; min-width: 240px; max-width: 320px; padding: 0.85rem 1.1rem; border-radius: 999px; border: 1.5px solid var(--line-2); background: var(--paper); color: var(--ink); font-size: 1rem; }
  .sub-form input:focus { outline: none; border-color: var(--indigo); box-shadow: 0 0 0 3px color-mix(in srgb, var(--indigo) 15%, transparent); }
  .sub-ok { flex-basis: 100%; color: var(--indigo-deep); font-weight: 600; margin-top: 0.3rem; }
  .sub-fine { color: var(--ink-faint); font-size: 0.78rem; margin-top: 1.2rem; }
  @media (max-width: 720px) { .sub-form input { max-width: none; } }
</style>

<script>
  const facts = [
    "Honey found in 3,000-year-old Egyptian tombs was still edible.",
    "A day on Venus is longer than its year.",
    "Bananas are botanically berries. Strawberries are not.",
    "Octopuses have three hearts and blue blood.",
    "The Eiffel Tower can be ~15 cm taller in summer heat.",
  ];
  const el = document.getElementById("fact");
  let i = 0;
  if (el) {
    setInterval(() => {
      i = (i + 1) % facts.length;
      el.style.opacity = "0";
      setTimeout(() => { el.textContent = facts[i]; el.style.opacity = "1"; }, 380);
    }, 4200);
  }
</script>
