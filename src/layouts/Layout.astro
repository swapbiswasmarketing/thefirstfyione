---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
}

const {
  title = "Strictly FYI - interesting things, strictly for your information",
  description = "A general-interest field guide to the fascinating - science, history, tech, culture, and everyday curiosities worth knowing. Strictly for your information.",
  image = "/og.png",
  type = "website",
  publishedTime,
  modifiedTime,
  section,
} = Astro.props;

const site = Astro.site ?? new URL("https://strictly.fyi");
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);
const year = new Date().getFullYear();

const nav = [
  { href: "/blog/", label: "Read" },
  { href: "/#topics", label: "Topics" },
  { href: "/about/", label: "About" },
];
const current = Astro.url.pathname;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Strictly FYI",
  url: site.href,
  description,
  publisher: {
    "@type": "Organization",
    name: "Strictly FYI",
    logo: { "@type": "ImageObject", url: new URL("/og.png", site).href },
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Strictly FYI" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Strictly FYI" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Strictly FYI - interesting things worth knowing" />
    {type === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === "article" && section && <meta property="article:section" content={section} />}
    {type === "article" && <meta property="article:author" content="Strictly FYI" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Strictly FYI" />

    <meta name="theme-color" content="#f7f5f0" />
    <link rel="alternate" type="application/rss+xml" title="Strictly FYI" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="site-head">
      <div class="wrap head-inner">
        <a href="/" class="brand" aria-label="Strictly FYI home">
          <span class="brand-strictly">Strictly</span><span class="brand-fyi hl">FYI</span>
        </a>
        <nav class="nav" id="nav" aria-label="Primary">
          {nav.map((n) => <a href={n.href} class={current === n.href ? "active" : ""}>{n.label}</a>)}
          <a href="/#subscribe" class="nav-cta">Subscribe</a>
        </nav>
        <div class="head-actions">
          <a href="/#subscribe" class="btn btn-primary btn-sm head-sub">Subscribe</a>
          <button id="nav-toggle" class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="nav">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap foot-top">
        <div class="foot-brand-col">
          <a href="/" class="brand foot-brand"><span class="brand-strictly">Strictly</span><span class="brand-fyi hl">FYI</span></a>
          <p>Interesting things, strictly for your information. A general-interest field guide to the fascinating.</p>
        </div>
        <div class="foot-col">
          <h4>Read</h4>
          <a href="/blog/">All stories</a>
          <a href="/#topics">Topics</a>
          <a href="/about/">About</a>
          <a href="/rss.xml">RSS feed</a>
        </div>
        <div class="foot-col">
          <h4>Stay curious</h4>
          <a href="/#subscribe">The weekly FYI</a>
          <a href="mailto:hello@strictly.fyi">hello@strictly.fyi</a>
        </div>
      </div>
      <div class="wrap foot-base">
        <span>© {year} Strictly FYI</span>
        <span class="mono">Interesting things, strictly for your information.</span>
      </div>
    </footer>

    <style>
      .skip { position: absolute; left: -999px; top: 0; background: var(--ink); color: var(--paper); padding: 0.6rem 1rem; z-index: 100; border-radius: 0 0 8px 0; }
      .skip:focus { left: 0; }

      .site-head { position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--paper) 84%, transparent); backdrop-filter: saturate(140%) blur(10px); border-bottom: 1px solid var(--line); }
      .head-inner { display: flex; align-items: center; gap: 1.5rem; padding: 0.85rem 0; }
      .brand { display: inline-flex; align-items: baseline; gap: 0.28rem; text-decoration: none; font-family: var(--serif); font-weight: 700; font-size: 1.42rem; letter-spacing: -0.02em; color: var(--ink); }
      .brand-fyi { font-family: var(--mono); font-weight: 700; font-size: 1.05rem; letter-spacing: 0.02em; }

      .nav { display: flex; gap: 1.5rem; margin-left: auto; align-items: center; }
      .nav a { color: var(--ink-soft); text-decoration: none; font-weight: 500; font-size: 0.96rem; padding: 0.3rem 0; border-bottom: 2px solid transparent; transition: color 0.15s, border-color 0.15s; }
      .nav a:hover, .nav a.active { color: var(--ink); border-color: var(--indigo); }
      .nav .nav-cta { display: none; }

      .head-actions { display: flex; align-items: center; gap: 0.7rem; }
      .btn-sm { padding: 0.55rem 1.1rem; font-size: 0.9rem; }
      .nav-toggle { display: none; place-items: center; width: 40px; height: 40px; border: 1.5px solid var(--line-2); border-radius: var(--radius); background: var(--paper-2); color: var(--ink); cursor: pointer; }
      .nav-toggle svg { width: 20px; height: 20px; }
      .nav-toggle:hover { border-color: var(--indigo); color: var(--indigo); }

      @media (max-width: 780px) {
        .head-sub { display: none; }
        .nav-toggle { display: grid; }
        .nav {
          position: fixed; inset: 0 0 0 auto; width: min(320px, 84vw);
          flex-direction: column; align-items: flex-start; gap: 0.2rem;
          background: var(--paper-2); border-left: 1px solid var(--line);
          padding: 5rem 1.5rem 2rem; margin: 0; z-index: 60;
          transform: translateX(105%); visibility: hidden;
          transition: transform 0.28s cubic-bezier(.4,0,.2,1), visibility 0.28s;
          box-shadow: var(--shadow-lift);
        }
        .nav.open { transform: none; visibility: visible; }
        .nav a { font-size: 1.15rem; width: 100%; border-bottom: 1px solid var(--line); padding: 0.8rem 0; }
        .nav .nav-cta { display: block; margin-top: 1rem; background: var(--indigo); color: #fff; text-align: center; border-radius: 999px; padding: 0.8rem; border-bottom: none; }
        .nav-backdrop { position: fixed; inset: 0; background: rgba(25,26,31,0.4); z-index: 55; opacity: 0; pointer-events: none; transition: opacity 0.28s; }
        .nav-backdrop.on { opacity: 1; pointer-events: auto; }
      }

      .site-foot { margin-top: clamp(4rem, 10vw, 7rem); background: var(--paper-deep); border-top: 1px solid var(--line); padding-top: clamp(2.5rem, 6vw, 4rem); }
      .foot-top { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 2rem; padding-bottom: 2.5rem; }
      .foot-brand-col p { color: var(--ink-soft); max-width: 34ch; margin-top: 0.6rem; }
      .foot-brand { font-size: 1.35rem; }
      .foot-col h4 { font-family: var(--mono); font-size: 0.74rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--indigo); margin-bottom: 0.7rem; }
      .foot-col a { display: block; color: var(--ink-soft); text-decoration: none; padding: 0.25rem 0; }
      .foot-col a:hover { color: var(--indigo-deep); }
      .foot-base { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; border-top: 1px solid var(--line); padding: 1.2rem 0; margin-top: 0.5rem; font-size: 0.85rem; color: var(--ink-faint); }
      @media (max-width: 720px) { .foot-top { grid-template-columns: 1fr; gap: 1.6rem; } .foot-base { flex-direction: column; gap: 0.4rem; } }
    </style>

    <script>
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } }
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      const nav = document.getElementById("nav");
      const navToggle = document.getElementById("nav-toggle");
      let backdrop: HTMLDivElement | null = null;
      function closeNav() { nav?.classList.remove("open"); navToggle?.setAttribute("aria-expanded", "false"); backdrop?.classList.remove("on"); }
      navToggle?.addEventListener("click", () => {
        const open = nav?.classList.toggle("open");
        navToggle.setAttribute("aria-expanded", String(!!open));
        if (open && !backdrop) { backdrop = document.createElement("div"); backdrop.className = "nav-backdrop"; document.body.appendChild(backdrop); backdrop.addEventListener("click", closeNav); }
        requestAnimationFrame(() => backdrop?.classList.toggle("on", !!open));
      });
      nav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeNav));
    </script>
  </body>
</html>
